{
  "name": "troubleshooting-panel-console-plugin",
  "version": "0.4.0",
  "private": true,
  "repository": "git@github.com:openshift/troubleshooting-panel-console-plugin",
  "license": "Apache-2.0",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run ts-node node_modules/.bin/webpack",
    "build-dev": "npm run clean && npm run ts-node node_modules/.bin/webpack",
    "start": "npm run ts-node node_modules/.bin/webpack serve",
    "start-console": "../scripts/start-console.sh",
    "start-forward": "../scripts/start-forward.sh",
    "i18n": "i18n-scripts/build-i18n.sh && node i18n-scripts/set-english-defaults.js",
    "ts-node": "ts-node -O '{\"module\":\"commonjs\"}'",
    "lint": "eslint ./src --fix &&  stylelint \"src/**/*.css\" --allow-empty-input --fix",
    "lint:tsc": "tsc --noEmit",
    "test:e2e": "scripts/run-e2e.sh",
    "test:unit": "jest --runInBand --logHeapUsage --config jest.config.js",
    "test:unit:watch": "jest --config jest.config.js --watch",
    "test:unit:coverage": "jest --config jest.config.js --coverage",
    "generate-client": "openapi-ts"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^3.14.7",
    "@cypress/grep": "^3.1.5",
    "@cypress/webpack-preprocessor": "^7.0.1",
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@hey-api/openapi-ts": "^0.95.0",
    "@openshift-console/dynamic-plugin-sdk": "^4.22.0-prerelease.2",
    "@openshift-console/dynamic-plugin-sdk-webpack": "^4.22.0-prerelease.2",
    "@patternfly/react-core": "^6.4.1",
    "@patternfly/react-icons": "^6.4.0",
    "@patternfly/react-topology": "^6.3.0",
    "@swc/core": "^1.15.24",
    "@swc/helpers": "^0.5.21",
    "@tanstack/react-query": "^5.97.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.19.15",
    "@types/react": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.58.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.7.1",
    "cypress": "^14.5.4",
    "cypress-multi-reporters": "^1.6.2",
    "esbuild-loader": "^4.4.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^2.12.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "i18next-parser": "^9.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jiti": "^2.6.1",
    "mocha-junit-reporter": "^2.2.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "pluralize": "^8.0.0",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "~16.5.8",
    "react-redux": "~9.2.0",
    "style-loader": "^3.3.1",
    "stylelint": "^15.3.0",
    "stylelint-config-standard": "^31.0.0",
    "swc-loader": "^0.2.7",
    "ts-jest": "^29.4.4",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "consolePlugin": {
    "name": "troubleshooting-panel-console-plugin",
    "version": "0.0.1",
    "displayName": "OpenShift Console Troubleshooting Panel Plugin",
    "description": "Troubleshooting Panel Plugin for OpenShift console. Used to display Korrel8r information",
    "exposedModules": {
      "TroubleshootingPanelActionsProvider": "./hooks/useTroubleshootingPanel",
      "TPReducer": "./redux-reducers",
      "NullContextProvider": "./components/NullContextProvider",
      "usePopover": "./hooks/usePopover"
    },
    "dependencies": {
      "@console/pluginAPI": "*"
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-common-types": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^0.2.6",
    "@jsdevtools/ono": "^7.1.3",
    "immutable": "^5.1.4",
    "react-router": "^7.13.2",
    "typesafe-actions": "^5.1.0"
  }
}
